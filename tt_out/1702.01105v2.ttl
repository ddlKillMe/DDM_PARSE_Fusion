askg-data:Paper-170201105v2-Section-7-Paragraph-71 a askg-onto:Paragraph ;
    rdfs:label "Paragraph 1"@en ;
    domo:Text "The dataset contains two main 3D modalities (3D point cloud data and 3D mesh model) and their semantic counterparts for each of the 6 areas. Statistics related to this modality are offered in Table [2.](#page-3-1)"@en ;
    askg-onto:hasSentence askg-data:Paper-170201105v2-Section-7-Paragraph-71-Sentence-711,
        askg-data:Paper-170201105v2-Section-7-Paragraph-71-Sentence-712 ;
    askg-onto:index "1"^^xsd:int ;
    askg-onto:numberOfSentences "2"^^xsd:positiveInteger .

askg-data:Paper-170201105v2-Section-7-Paragraph-71-Sentence-711 a askg-onto:Sentence ;
    rdfs:label "Sentence 1"@en ;
    domo:Text "The dataset contains two main 3D modalities (3D point cloud data and 3D mesh model) and their semantic counterparts for each of the 6 areas."@en ;
    askg-onto:index "1"^^xsd:int .

