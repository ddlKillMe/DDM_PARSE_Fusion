askg-data:Paper-170201105v2-Section-10-Paragraph-101 a askg-onto:Paragraph ;
    rdfs:label "Paragraph 1"@en ;
    domo:Text "Figure [7](#page-8-0) provides a representative sample of the generated data showing the diversity of the indoor scenes, in terms of scene category, appearance, intra-class variation, density of objects and amount of clutter. This also shows the varying degree of difficulty of the data, which consists of both easy and hard examples."@en ;
    askg-onto:hasCitation "[7]" ;
    askg-onto:hasSentence askg-data:Paper-170201105v2-Section-10-Paragraph-101-Sentence-1011,
        askg-data:Paper-170201105v2-Section-10-Paragraph-101-Sentence-1012 ;
    askg-onto:index "1"^^xsd:int ;
    askg-onto:numberOfSentences "2"^^xsd:positiveInteger .

