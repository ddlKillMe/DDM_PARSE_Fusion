    rdfs:label "Sentence 1"@en ;
    domo:Text "Figure 4: Sampling images from the equirectangular projection."@en ;
    askg-onto:index "1"^^xsd:int .

askg-data:Paper-170201105v2-Section-8-Paragraph-83-Sentence-832 a askg-onto:Sentence ;
    rdfs:label "Sentence 2"@en ;
