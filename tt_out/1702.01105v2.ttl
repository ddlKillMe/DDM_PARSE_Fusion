    rdfs:label "Sentence 2"@en ;
    domo:Text "Kinect [\\[5\\]](#page-7-8), Structure Sensor [\\[3\\]](#page-7-9), RealSense [\\[4\\]](#page-7-10), etc)."@en ;
    askg-onto:index "2"^^xsd:int .

