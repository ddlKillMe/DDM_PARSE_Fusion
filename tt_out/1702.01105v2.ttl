askg-data:Paper-170201105v2-Section-8-Paragraph-81 a askg-onto:Paragraph ;
    rdfs:label "Paragraph 1"@en ;
    domo:Text "The dataset contains densely sampled RGB images per scan location. These images were sampled from equirectangular images that were generated per scan location and modality using the raw data captured by the scanner (also"@en ;
    askg-onto:hasSentence askg-data:Paper-170201105v2-Section-8-Paragraph-81-Sentence-811,
        askg-data:Paper-170201105v2-Section-8-Paragraph-81-Sentence-812 ;
