askg-data:Paper-170201105v2-Section-2-Paragraph-21 a askg-onto:Paragraph ;
    rdfs:label "Paragraph 1"@en ;
    domo:Text "*We present a dataset of large-scale indoor spaces that provides a variety of mutually registered modalities from 2D, 2.5D and 3D domains, with instance-level semantic and geometric annotations. The dataset covers over 6,000* m2 *and contains over 70,000 RGB images, along with the corresponding depths, surface normals, semantic annotations, global XYZ images (all in forms of both regular and* 360◦ *equirectangular images) as well as camera information. It also includes registered raw and semantically annotated 3D meshes and point clouds. The dataset enables development of joint and cross-modal learning models and potentially unsupervised approaches utilizing the regularities present in large-scale indoor spaces.*"@en ;
    askg-onto:hasSentence askg-data:Paper-170201105v2-Section-2-Paragraph-21-Sentence-211,
        askg-data:Paper-170201105v2-Section-2-Paragraph-21-Sentence-212,
        askg-data:Paper-170201105v2-Section-2-Paragraph-21-Sentence-213,
        askg-data:Paper-170201105v2-Section-2-Paragraph-21-Sentence-214 ;
    askg-onto:index "1"^^xsd:int ;
    askg-onto:numberOfSentences "4"^^xsd:positiveInteger .

askg-data:Paper-170201105v2-Section-2-Paragraph-21-Sentence-211 a askg-onto:Sentence ;
    rdfs:label "Sentence 1"@en ;
    domo:Text "*We present a dataset of large-scale indoor spaces that provides a variety of mutually registered modalities from 2D, 2.5D and 3D domains, with instance-level semantic and geometric annotations."@en ;
    askg-onto:index "1"^^xsd:int .

askg-data:Paper-170201105v2-Section-2-Paragraph-21-Sentence-212 a askg-onto:Sentence ;
    rdfs:label "Sentence 2"@en ;
    domo:Text "The dataset covers over 6,000* m2 *and contains over 70,000 RGB images, along with the corresponding depths, surface normals, semantic annotations, global XYZ images (all in forms of both regular and* 360◦ *equirectangular images) as well as camera information."@en ;
    askg-onto:index "2"^^xsd:int .

askg-data:Paper-170201105v2-Section-2-Paragraph-21-Sentence-213 a askg-onto:Sentence ;
    rdfs:label "Sentence 3"@en ;
    domo:Text "It also includes registered raw and semantically annotated 3D meshes and point clouds."@en ;
    askg-onto:index "3"^^xsd:int .

askg-data:Paper-170201105v2-Section-2-Paragraph-21-Sentence-214 a askg-onto:Sentence ;
    rdfs:label "Sentence 4"@en ;
    domo:Text "The dataset enables development of joint and cross-modal learning models and potentially unsupervised approaches utilizing the regularities present in large-scale indoor spaces.*"@en ;
    askg-onto:index "4"^^xsd:int .

askg-data:Paper-170201105v2-Section-3 a askg-onto:Section ;
    rdfs:label "Section 3"@en ;
    domo:Text "1. [I](#page-0-0)ntroduction"@en ;
    askg-onto:hasParagraph askg-data:Paper-170201105v2-Section-3-Paragraph-31,
        askg-data:Paper-170201105v2-Section-3-Paragraph-32,
        askg-data:Paper-170201105v2-Section-3-Paragraph-33,
        askg-data:Paper-170201105v2-Section-3-Paragraph-34,
        askg-data:Paper-170201105v2-Section-3-Paragraph-35,
        askg-data:Paper-170201105v2-Section-3-Paragraph-36,
        askg-data:Paper-170201105v2-Section-3-Paragraph-37,
        askg-data:Paper-170201105v2-Section-3-Paragraph-38,
        askg-data:Paper-170201105v2-Section-3-Paragraph-39 ;
    askg-onto:index "3"^^xsd:int ;
    askg-onto:level "1"^^xsd:int ;
