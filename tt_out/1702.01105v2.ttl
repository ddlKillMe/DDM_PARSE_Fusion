    askg-onto:hasCitation "[7]" ;
    askg-onto:index "1"^^xsd:int .

askg-data:Paper-170201105v2-Section-10-Paragraph-101-Sentence-1012 a askg-onto:Sentence ;
    rdfs:label "Sentence 2"@en ;
    domo:Text "This also shows the varying degree of difficulty of the data, which consists of both easy and hard examples."@en ;
    askg-onto:index "2"^^xsd:int .

askg-data:Paper-170201105v2-Section-11 a askg-onto:Section ;
    rdfs:label "Section 11"@en ;
    domo:Text "6. Train and Test splits"@en ;
    askg-onto:hasParagraph askg-data:Paper-170201105v2-Section-11-Paragraph-111 ;
    askg-onto:index "11"^^xsd:int ;
    askg-onto:level "1"^^xsd:int ;
    askg-onto:numberOfSentences "2"^^xsd:positiveInteger .

askg-data:Paper-170201105v2-Section-11-Paragraph-111 a askg-onto:Paragraph ;
    rdfs:label "Paragraph 1"@en ;
    domo:Text "Certain areas in the dataset represent parts of buildings with similarities in their appearance and architectural features, thus we define standard training and testing splits so that no areas from similarly looking buildings appear in both. We split the 6 areas in the dataset as per Table [5](#page-5-2) and follow a 3-fold cross-validation scheme."@en ;
    askg-onto:hasCitation "[5]" ;
    askg-onto:hasSentence askg-data:Paper-170201105v2-Section-11-Paragraph-111-Sentence-1111,
        askg-data:Paper-170201105v2-Section-11-Paragraph-111-Sentence-1112 ;
    askg-onto:index "1"^^xsd:int ;
    askg-onto:numberOfSentences "2"^^xsd:positiveInteger .

askg-data:Paper-170201105v2-Section-11-Paragraph-111-Sentence-1111 a askg-onto:Sentence ;
    rdfs:label "Sentence 1"@en ;
    domo:Text "Certain areas in the dataset represent parts of buildings with similarities in their appearance and architectural features, thus we define standard training and testing splits so that no areas from similarly looking buildings appear in both."@en ;
    askg-onto:index "1"^^xsd:int .

askg-data:Paper-170201105v2-Section-11-Paragraph-111-Sentence-1112 a askg-onto:Sentence ;
    rdfs:label "Sentence 2"@en ;
    domo:Text "We split the 6 areas in the dataset as per Table [5](#page-5-2) and follow a 3-fold cross-validation scheme."@en ;
    askg-onto:hasCitation "[5]" ;
    askg-onto:index "2"^^xsd:int .

askg-data:Paper-170201105v2-Section-12 a askg-onto:Section ;
    rdfs:label "Section 12"@en ;
    domo:Text "7. Baseline Results"@en ;
    askg-onto:hasParagraph askg-data:Paper-170201105v2-Section-12-Paragraph-121 ;
    askg-onto:index "12"^^xsd:int ;
    askg-onto:level "1"^^xsd:int ;
    askg-onto:numberOfSentences "9"^^xsd:positiveInteger .

askg-data:Paper-170201105v2-Section-12-Paragraph-121 a askg-onto:Paragraph ;
    rdfs:label "Paragraph 1"@en ;
    domo:Text "As a baseline, we provide results on the task of 3D object detection, performed on the 3D point clouds from this paper [\\[1\\]](#page-7-7). The method follows a hierarchical approach to semantic parsing of large-scale data: first, we parse the raw data into semantically meaningful spaces (*e.g*. rooms, etc) and align them into a canonical reference coordinate system. Second, we parse each of these spaces into comprising elements that belong to one of the 12 available classes. We implement the first step with an unsupervised approach, and the second by training one-vs-all SVMs for each object class. We also employ a CRF for contextual consistency. Our experimental setup follows Table [5.](#page-5-2) For more details we refer the reader to [\\[1\\]](#page-7-7). Table [6](#page-6-0) tabulates the quantitative results of this baseline on the proposed dataset. Figure [6](#page-6-1) showcases sample qualitative results."@en ;
    askg-onto:hasCitation "[6]" ;
    askg-onto:hasSentence askg-data:Paper-170201105v2-Section-12-Paragraph-121-Sentence-1211,
        askg-data:Paper-170201105v2-Section-12-Paragraph-121-Sentence-1212,
        askg-data:Paper-170201105v2-Section-12-Paragraph-121-Sentence-1213,
        askg-data:Paper-170201105v2-Section-12-Paragraph-121-Sentence-1214,
        askg-data:Paper-170201105v2-Section-12-Paragraph-121-Sentence-1215,
        askg-data:Paper-170201105v2-Section-12-Paragraph-121-Sentence-1216,
        askg-data:Paper-170201105v2-Section-12-Paragraph-121-Sentence-1217,
        askg-data:Paper-170201105v2-Section-12-Paragraph-121-Sentence-1218,
        askg-data:Paper-170201105v2-Section-12-Paragraph-121-Sentence-1219 ;
    askg-onto:index "1"^^xsd:int ;
    askg-onto:numberOfSentences "9"^^xsd:positiveInteger .

