        askg-data:Paper-170201105v2-Section-7-Paragraph-79-Sentence-794,
        askg-data:Paper-170201105v2-Section-7-Paragraph-79-Sentence-795,
        askg-data:Paper-170201105v2-Section-7-Paragraph-79-Sentence-796 ;
    askg-onto:index "9"^^xsd:int ;
    askg-onto:numberOfSentences "6"^^xsd:positiveInteger .

askg-data:Paper-170201105v2-Section-7-Paragraph-79-Sentence-791 a askg-onto:Sentence ;
    rdfs:label "Sentence 1"@en ;
