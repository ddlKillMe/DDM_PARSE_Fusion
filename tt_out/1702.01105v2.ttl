askg-data:Paper-170201105v2-Section-13 a askg-onto:Section ;
    rdfs:label "Section 13"@en ;
    domo:Text "8. Conclusion"@en ;
    askg-onto:hasParagraph askg-data:Paper-170201105v2-Section-13-Paragraph-131,
        askg-data:Paper-170201105v2-Section-13-Paragraph-132,
        askg-data:Paper-170201105v2-Section-13-Paragraph-133,
