askg-data:Paper-170201105v2-Section-8-Paragraph-811-Sentence-8111 a askg-onto:Sentence ;
    rdfs:label "Sentence 1"@en ;
    domo:Text "Depth Images: For each image, we provide the depth, which was computed from the 3D mesh instead of directly from the scanner."@en ;
    askg-onto:index "1"^^xsd:int .

askg-data:Paper-170201105v2-Section-8-Paragraph-811-Sentence-8112 a askg-onto:Sentence ;
    rdfs:label "Sentence 2"@en ;
    domo:Text "We rendered these images from the 3D mesh by saving out depth information from the z-buffer in Blender."@en ;
    askg-onto:index "2"^^xsd:int .

askg-data:Paper-170201105v2-Section-8-Paragraph-811-Sentence-8113 a askg-onto:Sentence ;
    rdfs:label "Sentence 3"@en ;
    domo:Text "The images are saved as 16-bit grayscale PNGs where one unit of change in pixel intensity (e.g."@en ;
    askg-onto:index "3"^^xsd:int .

askg-data:Paper-170201105v2-Section-8-Paragraph-811-Sentence-8114 a askg-onto:Sentence ;
    rdfs:label "Sentence 4"@en ;
    domo:Text "a value from 45 to 46) corresponds to a 1 512m change in depth."@en ;
    askg-onto:index "4"^^xsd:int .

askg-data:Paper-170201105v2-Section-8-Paragraph-811-Sentence-8115 a askg-onto:Sentence ;
    rdfs:label "Sentence 5"@en ;
    domo:Text "The maximum observable range is therefore about 128 meters (2 16 · 1 512 )."@en ;
    askg-onto:index "5"^^xsd:int .

askg-data:Paper-170201105v2-Section-8-Paragraph-811-Sentence-8116 a askg-onto:Sentence ;
    rdfs:label "Sentence 6"@en ;
    domo:Text "All depths beyond this maximum distance assume the maximum value (65,535)."@en ;
    askg-onto:index "6"^^xsd:int .

askg-data:Paper-170201105v2-Section-8-Paragraph-811-Sentence-8117 a askg-onto:Sentence ;
    rdfs:label "Sentence 7"@en ;
    domo:Text "Pixels that correspond to locations where there is no depth information also take this maximum distance."@en ;
    askg-onto:index "7"^^xsd:int .

