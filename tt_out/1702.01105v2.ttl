askg-data:Paper-170201105v2-Section-8-Paragraph-87 a askg-onto:Paragraph ;
    rdfs:label "Paragraph 7"@en ;
    domo:Text "RGB Images: We use the provided raw RGB data to form a cubemap per scan location and sample new images in this space. We randomly sample the camera's euler angles as follows (Figure [5\\)](#page-4-1): (a) yaw: uniform in [−180◦ , 180◦ ], (b) pitch: Gaussian with zero mean and 15◦ standard deviation, and (c) roll: always zero. Field of View (FOV) angles are sampled from a half Gaussian distribution with 75◦ mean and −30◦ standard deviation."@en ;
    askg-onto:hasSentence askg-data:Paper-170201105v2-Section-8-Paragraph-87-Sentence-871,
        askg-data:Paper-170201105v2-Section-8-Paragraph-87-Sentence-872,
        askg-data:Paper-170201105v2-Section-8-Paragraph-87-Sentence-873 ;
    askg-onto:index "7"^^xsd:int ;
    askg-onto:numberOfSentences "3"^^xsd:positiveInteger .

askg-data:Paper-170201105v2-Section-8-Paragraph-87-Sentence-871 a askg-onto:Sentence ;
    rdfs:label "Sentence 1"@en ;
    domo:Text "RGB Images: We use the provided raw RGB data to form a cubemap per scan location and sample new images in this space."@en ;
    askg-onto:index "1"^^xsd:int .

askg-data:Paper-170201105v2-Section-8-Paragraph-87-Sentence-872 a askg-onto:Sentence ;
    rdfs:label "Sentence 2"@en ;
    domo:Text "We randomly sample the camera's euler angles as follows (Figure [5\\)](#page-4-1): (a) yaw: uniform in [−180◦ , 180◦ ], (b) pitch: Gaussian with zero mean and 15◦ standard deviation, and (c) roll: always zero."@en ;
    askg-onto:index "2"^^xsd:int .

askg-data:Paper-170201105v2-Section-8-Paragraph-87-Sentence-873 a askg-onto:Sentence ;
    rdfs:label "Sentence 3"@en ;
    domo:Text "Field of View (FOV) angles are sampled from a half Gaussian distribution with 75◦ mean and −30◦ standard deviation."@en ;
    askg-onto:index "3"^^xsd:int .

askg-data:Paper-170201105v2-Section-8-Paragraph-88 a askg-onto:Paragraph ;
    rdfs:label "Paragraph 8"@en ;
    domo:Text "To avoid having images that are uninteresting in terms of semantic content (*e.g*. only a plain wall), we generate 3×24 images per scan location and preserve approximately 70% of them by sampling based on semantic content entropy. We perform the entropy sampling as follows: we compute Shannon's entropy for each image on the pixel distribution of semantic classes therein (i.e. a 13 bin distribution). We then discard the bottom ∼15% (as such cases correspond to images with very small semantic value, *e.g*. a close up of a wall) and preserve the top ∼60% (the semantically diverse images). Out of the rest of the images, we preserve about 50% of them by sampling the entropy values on a half Gaussian with mean and standard deviation of 1 and - 1 2 , respectively."@en ;
    askg-onto:hasSentence askg-data:Paper-170201105v2-Section-8-Paragraph-88-Sentence-881,
        askg-data:Paper-170201105v2-Section-8-Paragraph-88-Sentence-882,
        askg-data:Paper-170201105v2-Section-8-Paragraph-88-Sentence-883,
        askg-data:Paper-170201105v2-Section-8-Paragraph-88-Sentence-884,
        askg-data:Paper-170201105v2-Section-8-Paragraph-88-Sentence-885,
        askg-data:Paper-170201105v2-Section-8-Paragraph-88-Sentence-886,
        askg-data:Paper-170201105v2-Section-8-Paragraph-88-Sentence-887 ;
    askg-onto:index "8"^^xsd:int ;
    askg-onto:numberOfSentences "7"^^xsd:positiveInteger .

