askg-data:Paper-170201105v2-Section-8-Paragraph-88-Sentence-887 a askg-onto:Sentence ;
    rdfs:label "Sentence 7"@en ;
    domo:Text "Out of the rest of the images, we preserve about 50% of them by sampling the entropy values on a half Gaussian with mean and standard deviation of 1 and - 1 2 , respectively."@en ;
    askg-onto:index "7"^^xsd:int .

askg-data:Paper-170201105v2-Section-8-Paragraph-89 a askg-onto:Paragraph ;
    rdfs:label "Paragraph 9"@en ;
    domo:Text "Using this approach, rather than simply discarding the low-entropy images, preserves the dataset's diversity by not completely removing low-entropy scenes. We rendered all images via Blender 2.78. Figure [4](#page-4-0) shows examples of sampled images per modality on an equirectangular image."@en ;
    askg-onto:hasCitation "[4]" ;
    askg-onto:hasSentence askg-data:Paper-170201105v2-Section-8-Paragraph-89-Sentence-891,
        askg-data:Paper-170201105v2-Section-8-Paragraph-89-Sentence-892,
        askg-data:Paper-170201105v2-Section-8-Paragraph-89-Sentence-893 ;
    askg-onto:index "9"^^xsd:int ;
    askg-onto:numberOfSentences "3"^^xsd:positiveInteger .

