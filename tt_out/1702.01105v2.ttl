    askg-onto:index "1"^^xsd:int .

askg-data:Paper-170201105v2-Section-7-Paragraph-79-Sentence-792 a askg-onto:Sentence ;
    rdfs:label "Sentence 2"@en ;
    domo:Text "Each object instance in the dataset has a unique identifier."@en ;
    askg-onto:index "2"^^xsd:int .

askg-data:Paper-170201105v2-Section-7-Paragraph-79-Sentence-793 a askg-onto:Sentence ;
    rdfs:label "Sentence 3"@en ;
    domo:Text "We also annotate the point cloud data into rooms and assign one of the following 11 scene labels to each: *office, conference room, hallway, auditorium, open space, lobby, lounge, pantry, copy room, storage* and *WC*."@en ;
    askg-onto:index "3"^^xsd:int .

askg-data:Paper-170201105v2-Section-7-Paragraph-79-Sentence-794 a askg-onto:Sentence ;
    rdfs:label "Sentence 4"@en ;
    domo:Text "Again, each instance in the point cloud receives a unique index."@en ;
    askg-onto:index "4"^^xsd:int .

askg-data:Paper-170201105v2-Section-7-Paragraph-79-Sentence-795 a askg-onto:Sentence ;
    rdfs:label "Sentence 5"@en ;
    domo:Text "Given these annotations, we calculate the tightest axis-aligned object bounding box of each instance and further voxelize it into a 6 × 6 × 6 grid with binary occupancy."@en ;
    askg-onto:index "5"^^xsd:int .

askg-data:Paper-170201105v2-Section-7-Paragraph-79-Sentence-796 a askg-onto:Sentence ;
