    askg-onto:index "1"^^xsd:int .

askg-data:Paper-170201105v2-Section-7-Paragraph-76-Sentence-762 a askg-onto:Sentence ;
    rdfs:label "Sentence 2"@en ;
    domo:Text "The RGB output of the scanner is registered on the 3D modalities (each yellow marker represents one scan)."@en ;
    askg-onto:index "2"^^xsd:int .

askg-data:Paper-170201105v2-Section-7-Paragraph-76-Sentence-763 a askg-onto:Sentence ;
    rdfs:label "Sentence 3"@en ;
    domo:Text "We then process the RGB and 3D data to make depth, surface normals, and 2D semantic (projected from 3D semantics) images for each scan."@en ;
    askg-onto:index "3"^^xsd:int .

askg-data:Paper-170201105v2-Section-7-Paragraph-76-Sentence-764 a askg-onto:Sentence ;
    rdfs:label "Sentence 4"@en ;
    domo:Text "The processed equirectangular images are sampled to make new regular images (shown in Figure [4\\)](#page-4-0)."@en ;
    askg-onto:index "4"^^xsd:int .

